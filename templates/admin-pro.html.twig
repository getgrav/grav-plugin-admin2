<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Pro — {{ site.title }}</title>
    <link rel="icon" type="image/svg+xml" href="/{{ admin_pro.app_url }}/_app/favicon.svg">

    <!-- Inject Grav config before app loads -->
    <script>
        window.__GRAV_CONFIG__ = {
            serverUrl: {{ admin_pro.server_url|json_encode|raw }},
            apiPrefix: {{ admin_pro.api_prefix|json_encode|raw }},
            basePath: {{ admin_pro.base_path|json_encode|raw }},
            environment: {{ admin_pro.environment|json_encode|raw }}
        };
    </script>

    <!-- SvelteKit app assets -->
    {% set app_base = '/' ~ admin_pro.app_url %}
    {{ assets.css(app_base ~ '/_app/immutable/assets/*.css')|raw }}
    <link rel="stylesheet" href="{{ app_base }}/app.css">
</head>
<body>
    <div id="app">
        <!-- SvelteKit mounts here -->
    </div>

    <script type="module" src="{{ app_base }}/app.js"></script>
</body>
</html>
